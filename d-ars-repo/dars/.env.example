# Neon Postgres (Vercel > Storage > Neon 연결 시 자동 주입)
# 미설정 시 앱은 데모 데이터(폴백)로 동작합니다.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ── 인증/인가 (기본 비활성 = 데모 통과) ─────────────────────────
# AUTH_ENFORCE=1 을 켜야 미들웨어/쓰기 API 인증이 실제로 차단합니다(미설정 시 전면 통과).
# AUTH_ENFORCE="1"
# 세션 토큰 HMAC 서명 키(운영 필수 · 임의의 긴 랜덤 문자열).
# AUTH_SECRET="change-me-to-a-long-random-string"
# 운영 계정 목록(JSON). 미설정 시 데모 계정 사용.
# AUTH_USERS='[{"u":"admin","p":"CHANGE_ME","role":"admin","name":"운영 관리자"}]'
# 콜봇 등 머신-투-머신 세션 수집(POST /api/sessions) 인증 키.
# AUTH_ENFORCE=1 이고 이 값이 설정된 경우에만 Authorization: Bearer <키> (또는 x-ingest-key) 를 요구합니다.
# INGEST_KEY="change-me-to-a-long-random-string"
